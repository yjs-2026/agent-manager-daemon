[Unit]
Description=Agent Manager Daemon (HTTPS web password self-service + agent upgrade API)
Documentation=https://github.com/yjs-2026/agent-manager-daemon
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
Group=root

# RuntimeDirectory= / StateDirectory= / LogsDirectory= / CacheDirectory=
# are systemd's first-class "create-if-missing" primitives. systemd
# creates them with the right ownership *before* ExecStart, which
# sidesteps the "Failed to set up mount namespacing" exit-226 issue
# we hit when using ReadWritePaths against a not-yet-created path.
# We override the defaults to match the names our config.yaml uses.
RuntimeDirectory=agent-manager
StateDirectory=agent-manager
LogsDirectory=agent-manager

# Listen on all interfaces (0.0.0.0) over HTTPS by default. Override
# AGENT_MANAGER_SERVER__BIND_HOST or AGENT_MANAGER_SERVER__BIND_PORT
# via an Environment= line below if you need to scope this down.
Environment="AGENT_MANAGER_CONFIG=/etc/agent-manager/config.yaml"
WorkingDirectory=/opt/agent-manager-daemon
# Use the console_script entry point (set up by [project.scripts] in
# pyproject.toml) instead of `python -m agent_manager`. The wrapper
# script does `from agent_manager.__main__ import main` via an
# absolute import, which is more robust than `python -m` because it
# doesn't depend on sys.path ordering when systemd sets a stripped
# environment or an unusual WorkingDirectory.
ExecStart=/opt/agent-manager-daemon/.venv/bin/agent-manager

# Hardening: we need /etc/shadow + chpasswd + systemctl, so a tight
# sandbox is impossible. Restrict what we *don't* need.
#
# MemoryDenyWriteExecute=false: CPython 3.12+ uses mmap(MAP_JIT) for
# certain code paths (notably cryptography import-time JIT, but also
# the in-process bytecode cache). MemoryDenyWriteExecute=true makes
# the daemon exit with code 226/NAMESPACE on first mmap. The cost of
# turning it off is small here because the daemon doesn't load
# untrusted code at runtime.
#
# NoNewPrivileges=false: chpasswd delegates the actual shadow write
# to /sbin/unix_chkpwd, which is setgid shadow. NoNewPrivileges=true
# disables setuid/setgid bit handling, so chpasswd can't reach the
# shadow file and pam_chauthtok() returns
# "Authentication token manipulation error". The daemon itself runs
# as root from the start, so this isn't a privilege escalation risk.
#
# ReadWritePaths is REQUIRED for paths we write to that aren't
# covered by RuntimeDirectory=/StateDirectory=/LogsDirectory=:
#   * /opt/myagent           — the agent's install_root
#     (NOT covered by StateDirectory=agent-manager, which only
#     creates /var/lib/agent-manager)
#   * /opt/agent-manager-daemon — daemon source + venv live here
#     and gunicorn workers need write access for bytecode cache
# Without ReadWritePaths, ProtectSystem=strict makes these paths
# read-only at mount-namespace setup time → exit-code 226/NAMESPACE
# with "No such file or directory" even when the path DOES exist.
#
# /var/lib/agent-manager and /var/log/agent-manager are already
# covered by StateDirectory=/LogsDirectory=agent-manager above
# but listing them again in ReadWritePaths is harmless and
# documents intent.
NoNewPrivileges=false
ProtectSystem=strict
ProtectHome=true
PrivateTmp=true
# /etc is in ReadWritePaths so the daemon can rewrite /etc/shadow
# when a user changes their password via the web UI. /etc is otherwise
# protected by ProtectSystem=strict (read-only bind mount); listing
# it here re-grants write access. The daemon is itself a privileged
# service that already has root + full caps, so the hardening loss
# is small.
ReadWritePaths=/var/lib/agent-manager /var/log/agent-manager /opt/agent-manager-daemon /opt/myagent /etc
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6
RestrictNamespaces=true
RestrictRealtime=true
SystemCallArchitectures=native
# SystemCallFilter= (empty) disables systemd's default syscall
# blacklist. The default (~) blocks groups like @clock, @debug, etc.,
# but in our case it also breaks chpasswd: chpasswd delegates the
# actual /etc/shadow write to /sbin/unix_chkpwd, which calls a
# syscall (chown on the new shadow file) that the default filter
# doesn't allow, causing pam_chauthtok() to fail with
# "Authentication token manipulation error".
#
# The daemon is itself a privileged service that talks to PAM, the
# shadow suite, systemctl, etc. — the syscalls we need are diverse
# enough that the default blacklist is more risk than benefit.
SystemCallFilter=
LockPersonality=true
MemoryDenyWriteExecute=false

Restart=on-failure
RestartSec=5s
# Cap the restart loop: if the daemon dies 5 times in 60s, give up
# and let `systemctl status` show the actual error instead of an
# endless "activating (auto-restart)" cycle.
StartLimitIntervalSec=60
StartLimitBurst=5
TimeoutStopSec=15

[Install]
WantedBy=multi-user.target